# Optional provider switch. Keep false unless keys below are configured.
VITE_ENABLE_API_KEY_PROVIDERS=false

# Experimental no-key sources. Keep false unless you accept undocumented upstreams.
VITE_ENABLE_EXPERIMENTAL_SOURCES=false

# Local development only. Routes Open-Meteo model requests through /api/openmeteo-proxy.
VITE_ENABLE_OPEN_METEO_DEV_PROXY=false
VITE_OPEN_METEO_DEV_PROXY=https://xle.cz/

# Split deploy (optional). Empty = same-origin /api (default on Vercel all-in-one or full VPS).
# When the UI is on Vercel and API on a VPS, set this at *Vercel build time* to the API origin:
# VITE_API_BASE=https://api.pocasi.smht.eu
VITE_API_BASE=

# On the API host (VPS), allow the frontend origin(s). Comma-separated, or * (default).
# CORS_ORIGINS=https://pocasi.smht.eu,http://localhost:5173
CORS_ORIGINS=*

# Dokploy / API-only host: refuse HTML UI, keep only /api/*.
# API_ONLY=true
# Optional browser redirect for non-API paths:
# FRONTEND_URL=https://pocasi.smht.eu

# Optional API-key weather providers. These are disabled by default.
WEATHERAPI_KEY=
PIRATEWEATHER_KEY=
OPENWEATHERMAP_KEY=
# Tomorrow.io (free tier ~3 rps / 25 req/h / 500/day). Also accepts TOMORROWIO_KEY.
TOMMOROWIO_KEY=
METEOSOURCE_KEY=
# free | flexi | standard — must match your Meteosource plan path (default free).
# METEOSOURCE_TIER=free
# Xweather / AerisWeather: either combined KEY as clientId_clientSecret, or separate vars.
XWEATHER_KEY=
# XWEATHER_CLIENT_ID=
# XWEATHER_CLIENT_SECRET=
# Weatherbit Free: 50 req/day, current + 7d daily only. Default tier=free (no hourly).
WEATHERBIT_KEY=
# WEATHERBIT_TIER=free
# WEATHERBIT_TIER=standard
ACCUWEATHER_KEY=
# Optional override for the public AccuWeather website key (current + 24 h hourly without a paid key).
# ACCUWEATHER_SITE_KEY=

# Optional PWS / history providers (also require VITE_ENABLE_API_KEY_PROVIDERS=true).
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=
NETATMO_REFRESH_TOKEN=
WUNDERGROUND_KEY=
METEOSTAT_KEY=

# Optional place-photo fallback. Used only by /api/place-image.
OPENTRIPMAP_API_KEY=

# Optional override for unofficial weather.com web API key (site embeds a public one by default).
# WEATHER_COM_API_KEY=
